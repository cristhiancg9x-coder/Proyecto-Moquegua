const { equipo } = Astro.props;
const waNumber = "51951413458"; // Número oficial

// Schema.org: Product
const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  name: equipo.nombre,
  image: [equipo.imagen],
  description: equipo.descripcionLarga,
  brand: {
    "@type": "Brand",
    name: equipo.nombre.split(" ")[0], // Extrae ej: "JBL" o "QSC"
  },
};
---

<Layout title={`${equipo.nombre} | Alquiler en AlquilerSonidoAxel`}>
  <!-- Inyección del Schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
    slot="head"
  />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 mt-16">
    <!-- Breadcrumbs -->
    <nav class="flex text-gray-500 text-sm mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-blue-600">Inicio</a>
        </li>
        <li>
          <div class="flex items-center">
            <svg
              class="w-4 h-4 text-gray-400 mx-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path></svg
            >
            <a href="/equipos" class="hover:text-blue-600">Equipos</a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg
              class="w-4 h-4 text-gray-400 mx-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path></svg
            >
            <span class="text-gray-900 font-medium" aria-current="page"
              >{equipo.nombre}</span
            >
          </div>
        </li>
      </ol>
    </nav>

    <!-- Detalles del Producto -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Imagen -->
      <div
        class="aspect-w-1 aspect-h-1 w-full bg-gray-100 rounded-2xl overflow-hidden border border-gray-200"
      >
        <Image
          src={equipo.imagen}
          alt={equipo.nombre}
          class="w-full h-full object-cover object-center"
        />
      </div>

      <!-- Info -->
      <div class="flex flex-col">
        <span
          class="text-xs font-bold tracking-widest text-blue-600 uppercase mb-2"
          >{equipo.categoria}</span
        >
        <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
          {equipo.nombre}
        </h1>

        <div class="mb-6">
          <a
            href={`https://wa.me/${waNumber}?text=Hola,%20deseo%20cotizar%20el%20alquiler%20de:%20${encodeURIComponent(equipo.nombre)}`}
            target="_blank"
            class="inline-flex items-center text-3xl font-extrabold text-blue-600 hover:text-blue-800 transition-colors"
          >
            Cotizar por WhatsApp
            <svg
              class="w-6 h-6 ml-2"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
            >
          </a>
        </div>

        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          {equipo.descripcionLarga}
        </p>

        <!-- Especificaciones -->
        <h3
          class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-200 pb-2"
        >
          Especificaciones Técnicas
        </h3>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-4 mb-10">
          {
            equipo.especificaciones.map((spec) => (
              <div class="border-t border-gray-100 pt-3">
                <dt class="text-sm font-medium text-gray-500">{spec.label}</dt>
                <dd class="mt-1 text-sm text-gray-900 font-semibold">
                  {spec.value}
                </dd>
              </div>
            ))
          }
        </dl>

        <!-- CTA Action -->
        <div class="mt-auto pt-8 flex border-t border-gray-200">
          <a
            href={`https://wa.me/${waNumber}?text=Hola,%20busco%20alquilar%20el%20equipo:%20${encodeURIComponent(equipo.nombre)}`}
            target="_blank"
            class="w-full flex justify-center items-center py-4 px-8 rounded-md shadow-sm text-lg font-bold text-white bg-blue-600 hover:bg-blue-700 transition-colors"
          >
            Preguntar Disponibilidad por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
