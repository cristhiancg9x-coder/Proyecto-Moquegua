---
const {
  title = "A & KATHERINE PRODUCCIONES | Sonido y Luces para Eventos",
  description = "A & KATHERINE PRODUCCIONES: Especialistas en alquiler de sonido profesional, luces y estructuras para bodas, fiestas y eventos corporativos en Moquegua, Perú.",
} = Astro.props;

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import "../styles/global.css";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "A & KATHERINE PRODUCCIONES",
  telephone: "+51953618734",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Moquegua",
    addressCountry: "PE",
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <meta
      name="google-site-verification"
      content="xOXdkPwNhxItaJLZzRdkpt6wBuusQZ4WOaDYlZKgCIY"
    />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="A & KATHERINE PRODUCCIONES" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Fallback / Theme Color -->
    <meta name="theme-color" content="#2563EB" />

    <!-- JSON-LD Structured Data Global -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(localBusinessSchema)}
    />

    <!-- Slot Head for Custom Injections (e.g. schema per page) -->
    <slot name="head" />
  </head>
  <body
    class="min-h-screen flex flex-col bg-gray-50 text-gray-900 font-sans mt-16 antialiased"
  >
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
